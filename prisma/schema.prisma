generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  firstName          String
  lastName           String
  address1           String
  city               String
  state              String
  postalCode         String
  dateOfBirth        String
  ssn                String
  dwollaCustomerId   String?
  dwollaCustomerUrl  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  banks                Bank[]
  sentTransactions     Transaction[] @relation("sender")
  receivedTransactions Transaction[] @relation("receiver")
  budgets              Budget[]
  savingsGoals         SavingsGoal[]
  alertRules           AlertRule[]
  transactionNotes     TransactionNote[]
  healthScores         FinancialHealthScore[]
  monthlyDigests       MonthlyDigest[]

  @@map("users")
}

model Bank {
  id               String   @id @default(uuid())
  userId           String
  bankId           String
  accountId        String
  accessToken      String
  fundingSourceUrl String?
  shareableId      String?
  createdAt        DateTime @default(now())

  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentTransactions     Transaction[] @relation("senderBank")
  receivedTransactions Transaction[] @relation("receiverBank")

  @@index([userId])
  @@index([accountId])
  @@map("banks")
}

model Transaction {
  id             String   @id @default(uuid())
  name           String
  amount         Decimal  @db.Decimal(12, 2)
  senderId       String
  senderBankId   String
  receiverId     String
  receiverBankId String
  email          String?
  channel        String   @default("online")
  category       String   @default("Transfer")
  createdAt      DateTime @default(now())

  sender       User @relation("sender", fields: [senderId], references: [id])
  senderBank   Bank @relation("senderBank", fields: [senderBankId], references: [id])
  receiver     User @relation("receiver", fields: [receiverId], references: [id])
  receiverBank Bank @relation("receiverBank", fields: [receiverBankId], references: [id])

  @@index([senderBankId])
  @@index([receiverBankId])
  @@map("transactions")
}

model CachedCategory {
  id              String   @id @default(uuid())
  transactionHash String   @unique
  originalName    String
  aiCategory      String
  createdAt       DateTime @default(now())

  @@index([transactionHash])
  @@map("cached_categories")
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  otpHash   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@map("otp_codes")
}

model Budget {
  id           String   @id @default(uuid())
  userId       String
  category     String
  monthlyLimit Decimal  @db.Decimal(12, 2)
  month        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month])
  @@index([userId, month])
  @@map("budgets")
}

model SavingsGoal {
  id           String    @id @default(uuid())
  userId       String
  name         String
  targetAmount Decimal   @db.Decimal(12, 2)
  savedAmount  Decimal   @db.Decimal(12, 2) @default(0)
  targetDate   DateTime?
  emoji        String?
  color        String?
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions GoalContribution[]

  @@index([userId, status])
  @@map("savings_goals")
}

model GoalContribution {
  id        String   @id @default(uuid())
  goalId    String
  amount    Decimal  @db.Decimal(12, 2)
  note      String?
  createdAt DateTime @default(now())

  goal SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("goal_contributions")
}

model AlertRule {
  id        String   @id @default(uuid())
  userId    String
  type      String
  category  String?
  threshold Decimal  @db.Decimal(12, 2)
  channel   String   @default("email")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  triggerLogs AlertTriggerLog[]

  @@index([userId, enabled])
  @@map("alert_rules")
}

model AlertTriggerLog {
  id          String   @id @default(uuid())
  ruleId      String
  triggeredAt DateTime @default(now())
  details     String

  rule AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, triggeredAt])
  @@map("alert_trigger_logs")
}

model TransactionNote {
  id              String   @id @default(uuid())
  transactionHash String
  userId          String
  note            String?
  tags            String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([transactionHash, userId])
  @@index([userId])
  @@index([transactionHash])
  @@map("transaction_notes")
}

model FinancialHealthScore {
  id          String   @id @default(uuid())
  userId      String
  month       String
  score       Int
  breakdown   Json
  tips        Json
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
  @@map("financial_health_scores")
}
