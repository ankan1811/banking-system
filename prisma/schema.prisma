generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  firstName          String
  lastName           String
  address1           String
  city               String
  state              String
  postalCode         String
  dateOfBirth        String
  ssn                String
  dwollaCustomerId   String?
  dwollaCustomerUrl  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  banks                Bank[]
  sentTransactions     Transaction[] @relation("sender")
  receivedTransactions Transaction[] @relation("receiver")
  budgets              Budget[]
  savingsGoals         SavingsGoal[]
  alertRules           AlertRule[]
  transactionNotes     TransactionNote[]
  healthScores         FinancialHealthScore[]
  monthlyDigests       MonthlyDigest[]
  splitGroups          SplitGroup[]
  spendingChallenges   SpendingChallenge[]
  challengeStreak      ChallengeStreak?
  badges               Badge[]
  manualAssets         ManualAsset[]
  manualLiabilities    ManualLiability[]
  netWorthSnapshots    NetWorthSnapshot[]

  @@map("users")
}

model Bank {
  id               String   @id @default(uuid())
  userId           String
  bankId           String
  accountId        String
  accessToken      String
  fundingSourceUrl String?
  shareableId      String?
  createdAt        DateTime @default(now())

  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentTransactions     Transaction[] @relation("senderBank")
  receivedTransactions Transaction[] @relation("receiverBank")

  @@index([userId])
  @@index([accountId])
  @@map("banks")
}

model Transaction {
  id             String   @id @default(uuid())
  name           String
  amount         Decimal  @db.Decimal(12, 2)
  senderId       String
  senderBankId   String
  receiverId     String
  receiverBankId String
  email          String?
  channel        String   @default("online")
  category       String   @default("Transfer")
  createdAt      DateTime @default(now())

  sender       User @relation("sender", fields: [senderId], references: [id])
  senderBank   Bank @relation("senderBank", fields: [senderBankId], references: [id])
  receiver     User @relation("receiver", fields: [receiverId], references: [id])
  receiverBank Bank @relation("receiverBank", fields: [receiverBankId], references: [id])

  @@index([senderBankId])
  @@index([receiverBankId])
  @@map("transactions")
}

model CachedCategory {
  id              String   @id @default(uuid())
  transactionHash String   @unique
  originalName    String
  aiCategory      String
  createdAt       DateTime @default(now())

  @@index([transactionHash])
  @@map("cached_categories")
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  otpHash   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@map("otp_codes")
}

model Budget {
  id           String   @id @default(uuid())
  userId       String
  category     String
  monthlyLimit Decimal  @db.Decimal(12, 2)
  month        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month])
  @@index([userId, month])
  @@map("budgets")
}

model SavingsGoal {
  id           String    @id @default(uuid())
  userId       String
  name         String
  targetAmount Decimal   @db.Decimal(12, 2)
  savedAmount  Decimal   @db.Decimal(12, 2) @default(0)
  targetDate   DateTime?
  emoji        String?
  color        String?
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions GoalContribution[]

  @@index([userId, status])
  @@map("savings_goals")
}

model GoalContribution {
  id        String   @id @default(uuid())
  goalId    String
  amount    Decimal  @db.Decimal(12, 2)
  note      String?
  createdAt DateTime @default(now())

  goal SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("goal_contributions")
}

model AlertRule {
  id        String   @id @default(uuid())
  userId    String
  type      String
  category  String?
  threshold Decimal  @db.Decimal(12, 2)
  channel   String   @default("email")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  triggerLogs AlertTriggerLog[]

  @@index([userId, enabled])
  @@map("alert_rules")
}

model AlertTriggerLog {
  id          String   @id @default(uuid())
  ruleId      String
  triggeredAt DateTime @default(now())
  details     String

  rule AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, triggeredAt])
  @@map("alert_trigger_logs")
}

model TransactionNote {
  id              String   @id @default(uuid())
  transactionHash String
  userId          String
  note            String?
  tags            String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([transactionHash, userId])
  @@index([userId])
  @@index([transactionHash])
  @@map("transaction_notes")
}

model FinancialHealthScore {
  id          String   @id @default(uuid())
  userId      String
  month       String
  score       Int
  breakdown   Json
  tips        Json
  source      String   @default("formula")
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
  @@map("financial_health_scores")
}

model MonthlyDigest {
  id              String   @id @default(uuid())
  userId          String
  month           String
  sections        Json
  narrative       String
  narrativeSource String   @default("formula")
  generatedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
  @@map("monthly_digests")
}

// ─── Split Expenses ───────────────────────────────────────────

model SplitGroup {
  id            String   @id @default(uuid())
  userId        String
  title         String
  totalAmount   Decimal  @db.Decimal(12, 2)
  transactionId String?
  splitType     String   @default("equal")
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants SplitParticipant[]

  @@index([userId, status])
  @@map("split_groups")
}

model SplitParticipant {
  id           String    @id @default(uuid())
  splitGroupId String
  email        String
  name         String
  amount       Decimal   @db.Decimal(12, 2)
  isPaid       Boolean   @default(false)
  paidAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  splitGroup SplitGroup @relation(fields: [splitGroupId], references: [id], onDelete: Cascade)

  @@index([splitGroupId])
  @@map("split_participants")
}

// ─── Spending Challenges ──────────────────────────────────────

model SpendingChallenge {
  id            String   @id @default(uuid())
  userId        String
  title         String
  description   String
  type          String
  category      String?
  targetAmount  Decimal? @db.Decimal(12, 2)
  duration      String
  startDate     DateTime
  endDate       DateTime
  status        String   @default("active")
  isAiGenerated Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, endDate])
  @@map("spending_challenges")
}

model ChallengeStreak {
  id             String   @id @default(uuid())
  userId         String   @unique
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  totalCompleted Int      @default(0)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("challenge_streaks")
}

model Badge {
  id        String   @id @default(uuid())
  userId    String
  badgeType String
  earnedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeType])
  @@index([userId])
  @@map("badges")
}

// ─── Net Worth Tracker ────────────────────────────────────────

model ManualAsset {
  id        String   @id @default(uuid())
  userId    String
  name      String
  category  String
  value     Decimal  @db.Decimal(14, 2)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("manual_assets")
}

model ManualLiability {
  id        String   @id @default(uuid())
  userId    String
  name      String
  category  String
  value     Decimal  @db.Decimal(14, 2)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("manual_liabilities")
}

model NetWorthSnapshot {
  id               String   @id @default(uuid())
  userId           String
  month            String
  linkedAssets     Decimal  @db.Decimal(14, 2)
  manualAssets     Decimal  @db.Decimal(14, 2)
  totalAssets      Decimal  @db.Decimal(14, 2)
  totalLiabilities Decimal  @db.Decimal(14, 2)
  netWorth         Decimal  @db.Decimal(14, 2)
  breakdown        Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
  @@map("net_worth_snapshots")
}
